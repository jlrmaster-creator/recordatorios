rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read/write own profile, read others in same group
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Invite codes: lookup by code when joining a group
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth.uid == getUserByGroupId(resource.data.groupId);
    }

    // Groups: members can list; any authenticated user can get a specific group by ID
    match /groups/{groupId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null && resource.data.members.hasAny([request.auth.uid]);
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    // Reminders: owner or recipient can read/write
    match /reminders/{reminderId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.ownerId ||
        request.auth.uid in resource.data.get('sharedWith', [])
      );
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.ownerId ||
        (request.resource.data.isShared == true && request.auth.uid == request.resource.data.sharedFrom)
      );
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerId
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.ownerId
      );
    }

    // Shared reminders log
    match /sharedReminders/{shareId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromUserId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.toUserId
      );
    }

    // Helper function
    function getUserByGroupId(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy;
    }
  }
}
